# App
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_JSON=false
API_KEY=change-me

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5442
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments

# RabbitMQ
# AMQP на 5662, management UI на 15672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5662
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Payments
 PAYMENTS_PROCESSING_MIN_SECONDS=2.0
 PAYMENTS_PROCESSING_MAX_SECONDS=5.0
 PAYMENTS_SUCCESS_RATE=0.9
 PAYMENTS_WEBHOOK_TIMEOUT_SECONDS=5.0
 PAYMENTS_WEBHOOK_MAX_RETRIES=3
 PAYMENTS_CONSUMER_MAX_RETRIES=3

# Outbox
 OUTBOX_POLL_INTERVAL_SECONDS=1.0
 OUTBOX_BATCH_SIZE=100
