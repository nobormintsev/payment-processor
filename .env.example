# App
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=false
API_KEY=local-dev-secret-change-me

# Postgres
# HOST=localhost для локального запуска приложения (вне Docker)
# Внутри docker-compose переопределяется на HOST=postgres
# PORT=5442 - чтобы не конфликтовать с локальным Postgres на 5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5442
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments

# RabbitMQ
# Аналогично Postgres: HOST=localhost локально, rabbitmq внутри compose
# AMQP на 5662, management UI на 15672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5662
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Payments (опциональные, есть дефолты)
# PAYMENTS_PROCESSING_MIN_SECONDS=2.0
# PAYMENTS_PROCESSING_MAX_SECONDS=5.0
# PAYMENTS_SUCCESS_RATE=0.9
# PAYMENTS_WEBHOOK_TIMEOUT_SECONDS=5.0
# PAYMENTS_WEBHOOK_MAX_RETRIES=3
# PAYMENTS_CONSUMER_MAX_RETRIES=3

# Outbox (опциональные)
# OUTBOX_POLL_INTERVAL_SECONDS=1.0
# OUTBOX_BATCH_SIZE=100
